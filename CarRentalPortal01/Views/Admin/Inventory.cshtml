@model IEnumerable<CarRentalPortal01.ViewModels.InventoryItemViewModel>

@{
    ViewData["Title"] = "Stok Durumu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="h3 mb-4 text-gray-800">Stok ve Envanter Durumu</h1>

<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Toplam Araç</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Sum(x => x.TotalCount)</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-car fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Müsait (Boşta)</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Sum(x => x.AvailableCount)</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-danger shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Kirada</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Sum(x => x.RentedCount)</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-key fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Bakımda / Serviste</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Sum(x => x.MaintenanceCount)</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-tools fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Model Bazlı Stok Dağılımı</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped" id="InventoryTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Marka & Model</th>
                        <th>Renk</th>
                        <th>Özellikler</th>
                        <th>Toplam Stok</th>
                        <th style="min-width: 250px;">Durum Dağılımı</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="font-weight-bold text-primary">@item.Brand</div>
                                <div class="small">@item.Model</div>
                            </td>
                            <td>
                                <span class="badge badge-light border">
                                    <i class="fas fa-palette mr-1"></i> @item.Color
                                </span>
                            </td>
                            <td>
                                <div class="small">@item.FuelType, @item.GearType</div>
                            </td>
                            <td class="text-center font-weight-bold" style="font-size:1.2em;">
                                @item.TotalCount
                            </td>
                            <td>
                                @{
                                    double total = (double)item.TotalCount;
                                    double availablePct = total > 0 ? (item.AvailableCount / total * 100) : 0;
                                    double rentedPct = total > 0 ? (item.RentedCount / total * 100) : 0;
                                    double maintenancePct = total > 0 ? (item.MaintenanceCount / total * 100) : 0;
                                }

                                <div class="d-flex align-items-center mb-1">

                                    <div class="progress flex-grow-1" style="height: 15px; background-color: #e9ecef;">

                                        @if (item.AvailableCount > 0)
                                        {
                                            <div class="progress-bar bg-success" role="progressbar"
                                                 style="width: @availablePct%"
                                                 title="@item.AvailableCount Müsait">
                                            </div>
                                        }

                                        @if (item.MaintenanceCount > 0)
                                        {
                                            <div class="progress-bar bg-warning" role="progressbar"
                                                 style="width: @maintenancePct%"
                                                 title="@item.MaintenanceCount Bakımda">
                                            </div>
                                        }

                                        @if (item.RentedCount > 0)
                                        {
                                            <div class="progress-bar bg-danger" role="progressbar"
                                                 style="width: @rentedPct%"
                                                 title="@item.RentedCount Kirada">
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between small text-muted" style="font-size: 0.8rem;">
                                    <span><i class="fas fa-circle text-success" style="font-size: 8px;"></i> @item.AvailableCount Müsait</span>

                                    @if (item.MaintenanceCount > 0)
                                    {
                                        <span><i class="fas fa-circle text-warning" style="font-size: 8px;"></i> <b>@item.MaintenanceCount Bakımda</b></span>
                                    }

                                    <span><i class="fas fa-circle text-danger" style="font-size: 8px;"></i> @item.RentedCount Kirada</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Admin/vendor/datatables/jquery.dataTables.min.js"></script>
    <script src="~/Admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#InventoryTable').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/tr.json" },
                "order": [[3, "desc"]]
            });
        });
    </script>
}